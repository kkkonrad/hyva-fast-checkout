{
  "name": "kkkonrad/fastcheckout",
  "description": "Dominate Checkout Open Source",
  "type": "magento2-module",
  "version": "6.1.1",
  "license": [
    "proprietary"
  ],
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "Kkkonrad\\Fastcheckout\\": ""
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.magento.com/"
    }
  ],
  "require": {
    "hyva-themes/magento2-theme-module": "^1.4",
    "magewirephp/magewire": "^1.13",
    "magento/framework": "103.*",
    "magento/module-catalog": "104.*",
    "magento/module-checkout": "100.*|101.*|102.*|103.*",
    "magento/module-checkout-agreements": "100.*",
    "magento/module-config": "101.*",
    "magento/module-customer": "103.*",
    "magento/module-directory": "100.*",
    "magento/module-downloadable": "100.*",
    "magento/module-gift-message": "100.*",
    "magento/module-newsletter": "100.*",
    "magento/module-sales": "100.*|101.*|102.*|103.*",
    "magento/module-quote": "100.*|101.*|102.*|103.*",
    "magento/module-payment": "100.*|101.*|102.*|103.*",
    "magento/module-shipping": "100.*",
    "magento/module-store": "101.*",
    "magento/module-tax": "100.*",
    "magento/module-theme": "101.*",
    "php": "~8.1.0|~8.2.0|~8.3.0|~8.4.0"
  },
  "suggest": {
    "smartmage/inpost": "Enables optional InPost parcel-locker checkout integration.",
    "tpaycom/magento2basic": "Enables the optional Tpay checkout compatibility patch."
  }
}
