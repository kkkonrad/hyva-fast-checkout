    $scriptString = <<<JS
require(['mage/template'], function (mageTemplate) {
    'use strict';

    var rowManager = {
        template: mageTemplate('<tr id="<%- _id %>">'
JS;

    foreach ($block->getColumns() as $columnName => $column) {
