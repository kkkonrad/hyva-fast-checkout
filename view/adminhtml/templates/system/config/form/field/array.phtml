        . <<<'JS'

        setElementValue: function (element, value) {
            var selectedValues;

            if (!element) {
                return;
            }

            if (element.multiple && Array.isArray(value)) {
                selectedValues = value.map(String);
                Array.prototype.forEach.call(element.options, function (option) {
                    option.selected = selectedValues.indexOf(option.value) !== -1;
                });
                return;
            }

            element.value = value == null ? '' : value;
        },

        bindRowActions: function (row, rowId) {
            var addAfter = row.querySelector('.action-add-after'),
                deleteButton = row.querySelector('.action-delete');

            if (addAfter) {
                addAfter.addEventListener('click', this.add.bind(this, null, rowId));
            }
            if (deleteButton) {
                deleteButton.addEventListener('click', this.del.bind(this, rowId));
            }
        },

        add: function (rowData, insertAfterId) {
            var templateValues = rowData,
                target,
                row,
                names;

            if (!templateValues) {
                templateValues = {
JS;

    foreach ($block->getColumns() as $columnName => $column) {
        $scriptString .= "                    " . $block->escapeJs($columnName) . ": '',\n"
            . "                    option_extra_attrs: {},\n";
    }

    $scriptString .= <<<'JS'
                    _id: 'row_' + Date.now() + '_' + Math.floor(Math.random() * 1000000)
                };
            }

            target = insertAfterId
                ? document.getElementById(insertAfterId)
                : document.getElementById('addRow__HTML_ID__');

            if (!target) {
                return;
            }

            target.insertAdjacentHTML(insertAfterId ? 'afterend' : 'beforeend', this.template(templateValues));
            row = document.getElementById(templateValues._id);
            if (!row) {
                return;
            }

            this.bindRowActions(row, templateValues._id);

            if (rowData && rowData.column_values) {
                names = Object.keys(rowData.column_values);
                names.forEach(function (name) {
                    rowManager.setElementValue(document.getElementById(name), rowData.column_values[name]);
                });
            }
        },

        del: function (rowId) {
            var row = document.getElementById(rowId);

            if (row) {
                row.remove();
            }
        }
    };

    document.getElementById('addToEndBtn__HTML_ID__').addEventListener('click', function () {
        rowManager.add(null, null);
    });

JS;

    $scriptString = str_replace('__HTML_ID__', $block->escapeJs($_htmlId), $scriptString);

