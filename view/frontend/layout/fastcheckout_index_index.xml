<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Kkkonrad_Fastcheckout::css/hyva-ko-payment.css"/>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="Kkkonrad\Fastcheckout\Block\Hyva\Checkout"
                   name="kkkonrad.fastcheckout.hyva.checkout"
                   template="Kkkonrad_Fastcheckout::hyva/checkout.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="magewire" xsi:type="object">Kkkonrad\Fastcheckout\Magewire\Checkout</argument>
                </arguments>
            </block>
            <block class="Kkkonrad\Fastcheckout\Block\Hyva\Checkout"
                   name="kkkonrad.fastcheckout.hyva.checkout.ko_checkout_bridge"
                   as="ko_checkout_bridge"
                   template="Kkkonrad_Fastcheckout::hyva/knockout/checkout-renderers.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
