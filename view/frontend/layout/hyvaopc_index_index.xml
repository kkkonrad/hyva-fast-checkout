<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="IWD_Opc::css/hyva-ko-payment.css"/>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="IWD\Opc\Block\Hyva\Checkout"
                   name="iwd.opc.hyva.checkout"
                   template="IWD_Opc::hyva/checkout.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="magewire" xsi:type="object">IWD\Opc\Magewire\Checkout</argument>
                </arguments>
            </block>
            <block class="IWD\Opc\Block\Hyva\Checkout"
                   name="iwd.opc.hyva.checkout.ko_payment_renderers"
                   as="ko_payment_renderers"
                   template="IWD_Opc::hyva/knockout/payment-renderers.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
