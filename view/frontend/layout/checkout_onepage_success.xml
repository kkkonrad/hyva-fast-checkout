<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <script src="Kkkonrad_Fastcheckout::js/ga4.js"/>
        <remove src="Tpay_Magento2::js/view/payment/success.js" />
        <script src="Kkkonrad_Fastcheckout::js/view/payment/tpay-success.js" />
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true" />
        <referenceBlock name="checkout.registration" remove="true" />
        <referenceContainer name="after.body.start">
            <block class="Kkkonrad\Fastcheckout\Block\Checkout\GA" name="ga" template="Kkkonrad_Fastcheckout::page/ga.phtml" ifconfig="google/analytics/active"/>
        </referenceContainer>
    </body>
</page>
