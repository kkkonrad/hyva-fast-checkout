<!-- GA4 -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        try {
            const purchaseData = <?= \Laminas\Json\Json::encode($block->getOrderDetailsForGa4()) ?>;
            if (typeof require !== 'undefined') {
                require([
                    'jquery',
                    'Kkkonrad_Fastcheckout/js/ga4Events'
                ], function ($, ga4Events) {
                    ga4Events.purchaseEvent(JSON.stringify(purchaseData));
                });
            } else if (window.checkoutData && window.checkoutData.ga4 && window.checkoutData.ga4.events) {
                window.checkoutData.ga4.events.sendPurchaseEventToGA(purchaseData);
            }
        } catch (e) {
            console.error('GA4 Event failed:', e);
        }
    });
</script>
