        <script>
            function checkoutSuccessRegister() {
                return {
                    formOpen: false,
                    accountCreated: false,
                    showPassword: false,
                    loading: false,
                    password: '',
                    errorMessage: '',
                    successMessage: '',
                    async submitRegisterForm() {
                        this.loading = true;
                        this.errorMessage = '';
                        try {
                            const response = await fetch("<?= $block->escapeUrl($block->getCreateAccountWithPasswordUrl()) ?>", {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/x-www-form-urlencoded',
                                    'X-Requested-With': 'XMLHttpRequest'
                                },
                                body: new URLSearchParams({ password: this.password })
                            });
                            const data = await response.json();
                            if (data.errors === false) {
                                this.accountCreated = true;
                                this.successMessage = data.message;
                            } else {
                                this.errorMessage = data.message || 'An error occurred during account creation.';
                            }
                        } catch (e) {
                            this.errorMessage = 'A network error occurred. Please try again.';
                        } finally {
                            this.loading = false;
                        }
                    }
                };
            }
        </script>
