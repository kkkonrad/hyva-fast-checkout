    .iwd-opc-ko-payment-root .payment-method-title,
    .iwd-opc-ko-payment-root .actions-toolbar,
    .iwd-opc-ko-payment-root .payment-method-billing-address,
    .iwd-opc-payment-method-ko-container .payment-method-title,
    .iwd-opc-payment-method-ko-container .actions-toolbar,
    .iwd-opc-payment-method-ko-container .payment-method-billing-address {
        display: none !important;
    }
</style>

<div id="iwd-opc-ko-payment-root"
     class="iwd-opc-ko-payment-root mt-4"
     style="display: none !important;"
     wire:ignore
     data-bind="scope: 'iwdOpcHyvaPaymentRenderers'">
    <!-- ko foreach: getRegion('payment-methods-list') -->
        <!-- ko template: getTemplate() --><!-- /ko -->
    <!-- /ko -->
</div>

<script>
(function () {
    var config = <?= /* @noEscape */ \Laminas\Json\Json::encode($mageInitConfig) ?>;
    var requireJsUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('requirejs/require.js')) ?>';
    var requireJsConfigUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('requirejs-config.js')) ?>';
    var staticBaseUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('/')) ?>';
    var started = false;

    window.LOCALE = window.LOCALE || '<?= $escaper->escapeJs($block->getLocaleCode()) ?>';
    window.BASE_URL = window.BASE_URL || '<?= $escaper->escapeJs($block->getBaseUrl()) ?>';

    function loadScript(src, onload) {
        var script = document.createElement('script');

        script.src = src;
        script.async = false;
        script.onload = onload;
        script.onerror = function () {
            if (window.console && typeof window.console.warn === 'function') {
                window.console.warn('IWD OPC: could not load script', src);
            }
        };
        document.head.appendChild(script);
    }

    function initPaymentRenderers() {
        if (started || typeof window.require !== 'function') {
            return;
        }

        started = true;
        window.require.config({
            baseUrl: staticBaseUrl
        });

        window.require(['IWD_Opc/js/hyva/payment-renderers'], function (init) {
            init(config);
        });
    }

    function loadRequireJs() {
        if (typeof window.require === 'function') {
            initPaymentRenderers();
            return;
        }

        loadScript(requireJsUrl, function () {
            loadScript(requireJsConfigUrl, initPaymentRenderers);
        });
    }

    function startAfterMagewire() {
        if (window.Magewire || window.Livewire) {
            loadRequireJs();
            return;
        }

        document.addEventListener('magewire:available', loadRequireJs, {once: true});
        document.addEventListener('livewire:available', loadRequireJs, {once: true});
        window.addEventListener('load', function () {
            setTimeout(loadRequireJs, 0);
        }, {once: true});
    }

    startAfterMagewire();
})();
</script>

<div id="iwd-opc-debug-console" style="position:fixed;bottom:10px;right:10px;width:400px;max-height:300px;overflow-y:auto;background:rgba(0,0,0,0.85);color:#0f0;font-family:monospace;font-size:11px;padding:12px;z-index:999999;border-radius:6px;border:1px solid #444;box-shadow:0 10px 15px -3px rgba(0,0,0,0.5);display:none;">
    <div style="border-bottom:1px solid #555;padding-bottom:5px;margin-bottom:8px;font-weight:bold;">
        IWD Checkout Debug Panel
        <button onclick="this.parentNode.parentNode.style.display='none'" style="float:right;background:#dc2626;color:#fff;border:none;padding:1px 5px;cursor:pointer;border-radius:3px;font-size:10px;">Close</button>
    </div>
    <div id="iwd-opc-debug-log" style="display:flex;flex-direction:column;gap:4px;"></div>
</div>
<script>
(function() {
    var debugLog = document.getElementById('iwd-opc-debug-log');
    var debugConsole = document.getElementById('iwd-opc-debug-console');
    if (window.location.search.indexOf('debug=1') !== -1) {
        debugConsole.style.display = 'block';
    }
    function logToScreen(type, args) {
        if (!debugLog) return;
        var msg = Array.prototype.slice.call(args).map(function(arg) {
            if (arg === null) return 'null';
            if (arg === undefined) return 'undefined';
            if (typeof arg === 'object') {
                try {
                    return JSON.stringify(arg);
                } catch (e) {
                    return '[Object ' + (arg.constructor ? arg.constructor.name : 'Object') + ']';
                }
            }
            return arg;
        }).join(' ');
        var item = document.createElement('div');
        item.style.color = type === 'warn' ? '#fbbf24' : (type === 'error' ? '#ef4444' : '#34d399');
        item.style.wordBreak = 'break-all';
        item.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;
        debugLog.appendChild(item);
        debugConsole.scrollTop = debugConsole.scrollHeight;
    }
    var origLog = console.log;
    console.log = function() {
        origLog.apply(console, arguments);
        logToScreen('log', arguments);
    };
    var origWarn = console.warn;
    console.warn = function() {
        origWarn.apply(console, arguments);
        logToScreen('warn', arguments);
    };
    var origError = console.error;
    console.error = function() {
        origError.apply(console, arguments);
        logToScreen('error', arguments);
    };
})();
</script>
