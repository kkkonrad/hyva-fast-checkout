<?php
/**
 * Knockout payment renderer island for the Hyva/Magewire checkout.
 *
 * @var \Kkkonrad\Fastcheckout\Block\Hyva\Checkout $block
 * @var \Magento\Framework\Escaper $escaper
 */

$checkoutConfig = $block->getCheckoutConfig();
$paymentMethods = $block->getData('payment_methods');
if (!is_array($paymentMethods) || $paymentMethods === []) {
    $paymentMethods = $checkoutConfig['paymentMethods'] ?? [];
}
$rendererComponents = $block->getPaymentRendererComponents();
$layoutScripts = $block->getCheckoutLayoutScripts();

if (empty($rendererComponents) && empty($layoutScripts['modules']) && empty($layoutScripts['external'])) {
    return;
}

$mageInitConfig = [
    'checkoutConfig' => $checkoutConfig,
    'paymentMethods' => $paymentMethods,
    'rendererComponents' => $rendererComponents,
    'layoutScripts' => $layoutScripts['modules'] ?? [],
    'scope' => 'iwdOpcHyvaPaymentRenderers'
];
$block->ensureRequireJsAssets();
?>
<style>
    .iwd-opc-ko-payment-root .payment-method-title,
    .iwd-opc-ko-payment-root .actions-toolbar,
    .iwd-opc-ko-payment-root .payment-method-billing-address,
    .iwd-opc-payment-method-ko-container .payment-method-title,
    .iwd-opc-payment-method-ko-container .actions-toolbar,
    .iwd-opc-payment-method-ko-container .payment-method-billing-address {
        display: none !important;
    }
</style>

<?php
$layoutAssets = $block->getCheckoutLayoutAssets();
foreach ($layoutAssets['css'] as $cssAsset) {
    $url = ($cssAsset['src_type'] === 'url') ? $cssAsset['src'] : $block->getViewFileUrl($cssAsset['src']);
    echo '<link rel="stylesheet" type="text/css" href="' . $escaper->escapeUrl($url) . '" />';
}
foreach ($layoutScripts['external'] as $externalScript) {
    echo '<script src="' . $escaper->escapeUrl($externalScript) . '"></script>';
}
?>

<div id="iwd-opc-ko-payment-root"
     class="iwd-opc-ko-payment-root mt-4"
     style="display: none !important;"
     wire:ignore
     data-bind="scope: 'iwdOpcHyvaPaymentRenderers'">
    <!-- ko foreach: getRegion('payment-methods-list') -->
        <!-- ko template: getTemplate() --><!-- /ko -->
    <!-- /ko -->
</div>

<script>
(function () {
    var config = <?= /* @noEscape */ \Laminas\Json\Json::encode($mageInitConfig) ?>;
    var requireJsUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('requirejs/require.js')) ?>';
    var requireJsConfigUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('requirejs-config.js')) ?>';
    var staticBaseUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('/')) ?>';
    var started = false;

    window.LOCALE = window.LOCALE || '<?= $escaper->escapeJs($block->getLocaleCode()) ?>';
    window.BASE_URL = window.BASE_URL || '<?= $escaper->escapeJs($block->getBaseUrl()) ?>';

    function loadScript(src, onload) {
        var script = document.createElement('script');

        script.src = src;
        script.async = false;
        script.onload = onload;
        script.onerror = function () {
            if (window.console && typeof window.console.warn === 'function') {
                window.console.warn('Kkkonrad OPC: could not load script', src);
            }
        };
        document.head.appendChild(script);
    }

    function initPaymentRenderers() {
        if (started || typeof window.require !== 'function') {
            return;
        }

        started = true;
        window.require.config({
            baseUrl: staticBaseUrl
        });

        window.require(['Kkkonrad_Fastcheckout/js/hyva/payment-renderers'], function (init) {
            init(config);
        });
    }

    function loadRequireJs() {
        if (typeof window.require === 'function') {
            initPaymentRenderers();
            return;
        }

        loadScript(requireJsUrl, function () {
            loadScript(requireJsConfigUrl, initPaymentRenderers);
        });
    }

    function startAfterMagewire() {
        if (window.Magewire || window.Livewire) {
            loadRequireJs();
            return;
        }

        document.addEventListener('magewire:available', loadRequireJs, {once: true});
        document.addEventListener('livewire:available', loadRequireJs, {once: true});
        window.addEventListener('load', function () {
            setTimeout(loadRequireJs, 0);
        }, {once: true});
    }

    startAfterMagewire();
})();
</script>
