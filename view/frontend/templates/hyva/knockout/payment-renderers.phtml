<?php
/**
 * Knockout payment renderer island for the Hyva/Magewire checkout.
 *
 * @var \Kkkonrad\Fastcheckout\Block\Hyva\Checkout $block
 * @var \Magento\Framework\Escaper $escaper
 */

$checkoutConfig = $block->getCheckoutConfig();
$paymentMethods = $block->getData('payment_methods');
if (!is_array($paymentMethods) || $paymentMethods === []) {
    $paymentMethods = $checkoutConfig['paymentMethods'] ?? [];
}
$rendererComponents = $block->getPaymentRendererComponents();
$rendererComponentMap = $block->getPaymentRendererComponentMap();
$shippingRatesValidationComponents = $block->getShippingRatesValidationComponents();
$paymentValidationComponents = $block->getPaymentValidationComponents();
$paymentListChildren = $block->getPaymentListChildren();
$paymentRegionChildren = $block->getPaymentRegionChildren();
$shippingListChildren = $block->getShippingListChildren();
$shippingAddressChildren = $block->getShippingAddressChildren();
$layoutScripts = $block->getCheckoutLayoutScripts();

if (
    empty($rendererComponents) &&
    empty($rendererComponentMap) &&
    empty($shippingRatesValidationComponents) &&
    empty($paymentValidationComponents) &&
    empty($paymentListChildren) &&
    empty($paymentRegionChildren) &&
    empty($shippingListChildren) &&
    empty($shippingAddressChildren) &&
    empty($layoutScripts['modules']) &&
    empty($layoutScripts['external'])
) {
    return;
}

$mageInitConfig = [
    'checkoutConfig' => $checkoutConfig,
    'paymentMethods' => $paymentMethods,
    'rendererComponents' => $rendererComponents,
    'rendererComponentMap' => $rendererComponentMap,
    'shippingRatesValidationComponents' => $shippingRatesValidationComponents,
    'paymentValidationComponents' => $paymentValidationComponents,
    'paymentListChildren' => $paymentListChildren,
    'paymentRegionChildren' => $paymentRegionChildren,
    'shippingListChildren' => $shippingListChildren,
    'shippingAddressChildren' => $shippingAddressChildren,
    'layoutScripts' => $layoutScripts['modules'] ?? [],
    'scope' => 'fastcheckoutHyvaPaymentRenderers'
];
$block->ensureRequireJsAssets();
?>
<style>
    .fastcheckout-ko-payment-root .payment-method-title,
    .fastcheckout-ko-payment-root .actions-toolbar,
    .fastcheckout-ko-payment-root .payment-method-billing-address,
    .fastcheckout-payment-method-ko-container .payment-method-title,
    .fastcheckout-payment-method-ko-container .actions-toolbar,
    .fastcheckout-payment-method-ko-container .payment-method-billing-address {
        display: none !important;
    }
</style>

<?php
$layoutAssets = $block->getCheckoutLayoutAssets();
foreach ($layoutAssets['css'] as $cssAsset) {
    $url = ($cssAsset['src_type'] === 'url') ? $cssAsset['src'] : $block->getViewFileUrl($cssAsset['src']);
    echo '<link rel="stylesheet" type="text/css" href="' . $escaper->escapeUrl($url) . '" />';
}
foreach ($layoutScripts['external'] as $externalScript) {
    echo '<script src="' . $escaper->escapeUrl($externalScript) . '"></script>';
}
?>

<div id="fastcheckout-ko-payment-root"
     class="fastcheckout-ko-payment-root mt-4"
     style="display: none !important;"
     wire:ignore
     data-bind="scope: 'fastcheckoutHyvaPaymentRenderers'">
    <!-- ko foreach: getRegion('place-order-captcha') -->
        <!-- ko template: getTemplate() --><!-- /ko -->
    <!-- /ko -->
    <!-- ko foreach: getRegion('beforeMethods') -->
        <!-- ko template: getTemplate() --><!-- /ko -->
    <!-- /ko -->
    <!-- ko foreach: getRegion('payment-methods-list') -->
        <!-- ko template: getTemplate() --><!-- /ko -->
    <!-- /ko -->
    <!-- ko foreach: getRegion('afterMethods') -->
        <!-- ko template: getTemplate() --><!-- /ko -->
    <!-- /ko -->
</div>

<script>
(function () {
    // Safely define checkoutConfig and payment config inline before RequireJS is loaded/executed
    // We use a getter/setter to prevent subsequent scripts (e.g. from PayPal_Braintree) from overwriting it completely and removing key structures
    var existingConfig = window.checkoutConfig || <?= /* @noEscape */ \Laminas\Json\Json::encode($checkoutConfig) ?>;
    var actualConfig = {};
    
    var initPaymentProxy = function(paymentObj) {
        paymentObj = paymentObj || {};
        // If it is already a Proxy, return it
        if (paymentObj.__isProxy) {
            return paymentObj;
        }
        return new Proxy(paymentObj, {
            get: function(target, prop) {
                if (prop === '__isProxy') {
                    return true;
                }
                if (prop === '__raw__') {
                    return target;
                }
                if (typeof prop === 'string' && !(prop in target)) {
                    target[prop] = {};
                }
                return target[prop];
            }
        });
    };

    Object.defineProperty(window, 'checkoutConfig', {
        get: function() {
            return actualConfig;
        },
        set: function(newConfig) {
            if (newConfig && typeof newConfig === 'object') {
                actualConfig = Object.assign(actualConfig, newConfig);
            } else {
                actualConfig = newConfig;
            }
            if (actualConfig && typeof actualConfig === 'object') {
                actualConfig.payment = initPaymentProxy(actualConfig.payment);
            }
        },
        configurable: true,
        enumerable: true
    });
    window.checkoutConfig = existingConfig;

    var config = <?= /* @noEscape */ \Laminas\Json\Json::encode($mageInitConfig) ?>;
    var requireJsUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('requirejs/require.js')) ?>';
    var requireJsConfigUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('requirejs-config.js')) ?>';
    var mixinsUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('mage/requirejs/mixins.js')) ?>';
    var staticBaseUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('/')) ?>';
    var started = false;

    window.LOCALE = window.LOCALE || '<?= $escaper->escapeJs($block->getLocaleCode()) ?>';
    window.BASE_URL = window.BASE_URL || '<?= $escaper->escapeJs($block->getBaseUrl()) ?>';

    function loadScript(src, onload) {
        var script = document.createElement('script');

        script.src = src;
        script.async = false;
        script.onload = onload;
        script.onerror = function () {
            if (window.console && typeof window.console.warn === 'function') {
                window.console.warn('Kkkonrad Fastcheckout: could not load script', src);
            }
        };
        document.head.appendChild(script);
    }

    var originalGetElementById = document.getElementById;
    var originalQuerySelector = document.querySelector;
    var originalQuerySelectorAll = document.querySelectorAll;

    function getFastcheckoutRoot() {
        return originalGetElementById.call(document, 'fastcheckout-checkout');
    }

    function shouldSkipShadowLookup(selector) {
        return typeof selector === 'string' && (
            selector.indexOf('wire:') !== -1 ||
            selector.indexOf('x-') !== -1 ||
            selector.indexOf('[wire') !== -1 ||
            selector.indexOf('[x-') !== -1 ||
            selector.indexOf('livewire') !== -1 ||
            selector.indexOf('alpine') !== -1
        );
    }

    function getPaymentPlaceholders() {
        if (!getFastcheckoutRoot()) {
            return [];
        }

        return originalQuerySelectorAll.call(document, '[data-fastcheckout-payment-method-ko-target]');
    }

    function setupDomOverrides() {
        if (window.fastcheckoutKoDomOverridesApplied || !getFastcheckoutRoot()) {
            return;
        }

        window.fastcheckoutKoDomOverridesApplied = true;

        document.getElementById = function (id) {
            var el = originalGetElementById.call(document, id);
            if (!el) {
                var placeholders = getPaymentPlaceholders();
                for (var i = 0; i < placeholders.length; i++) {
                    if (placeholders[i].shadowRoot) {
                        el = placeholders[i].shadowRoot.getElementById(id);
                        if (el) break;
                    }
                }
            }
            return el;
        };

        document.querySelector = function (selector) {
            var el = originalQuerySelector.call(document, selector);
            if (!el) {
                if (shouldSkipShadowLookup(selector)) {
                    return el;
                }

                var placeholders = getPaymentPlaceholders();
                for (var i = 0; i < placeholders.length; i++) {
                    if (placeholders[i].shadowRoot) {
                        el = placeholders[i].shadowRoot.querySelector(selector);
                        if (el) break;
                    }
                }
            }
            return el;
        };

        document.querySelectorAll = function (selector) {
            var lightList = Array.from(originalQuerySelectorAll.call(document, selector));
            
            if (shouldSkipShadowLookup(selector)) {
                return lightList;
            }

            var shadowElements = [];
            var placeholders = getPaymentPlaceholders();
            for (var i = 0; i < placeholders.length; i++) {
                if (placeholders[i].shadowRoot) {
                    placeholders[i].shadowRoot.querySelectorAll(selector).forEach(function (el) {
                        shadowElements.push(el);
                    });
                }
            }
            return lightList.concat(shadowElements);
        };
    }

    function initPaymentRenderers() {
        if (started || window.fastcheckoutKoPaymentRenderersStarted || typeof window.require !== 'function') {
            return;
        }

        setupDomOverrides();

        started = true;
        window.fastcheckoutKoPaymentRenderersStarted = true;
        window.require.config({
            baseUrl: staticBaseUrl
        });

        window.require(['Kkkonrad_Fastcheckout/js/hyva/payment-renderers'], function (init) {
            init(config);
        });
    }

    function loadRequireJs() {
        if (typeof window.require === 'function') {
            window.require.config({
                baseUrl: staticBaseUrl
            });
            initPaymentRenderers();
            return;
        }

        loadScript(requireJsUrl, function () {
            if (typeof window.require === 'function') {
                window.require.config({
                    baseUrl: staticBaseUrl
                });
            }
            loadScript(requireJsConfigUrl, function () {
                loadScript(mixinsUrl, initPaymentRenderers);
            });
        });
    }

    function startAfterMagewire() {
        if (window.Magewire || window.Livewire) {
            loadRequireJs();
            return;
        }

        document.addEventListener('magewire:available', loadRequireJs, {once: true});
        document.addEventListener('livewire:available', loadRequireJs, {once: true});
        window.addEventListener('load', function () {
            setTimeout(loadRequireJs, 0);
        }, {once: true});
    }

    startAfterMagewire();
})();
</script>
