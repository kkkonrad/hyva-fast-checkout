<?php
/**
 * Knockout checkout bridge island for the Hyva/Magewire checkout.
 *
 * @var \Kkkonrad\Fastcheckout\Block\Hyva\Checkout $block
 * @var \Magento\Framework\Escaper $escaper
 */

$checkoutConfig = $block->getCheckoutConfig();
$paymentMethods = $block->getData('payment_methods');
if (!is_array($paymentMethods) || $paymentMethods === []) {
    $paymentMethods = $checkoutConfig['paymentMethods'] ?? [];
}
$rendererComponents = $block->getPaymentRendererComponents();
$rendererComponentMap = $block->getPaymentRendererComponentMap();
$shippingRatesValidationComponents = $block->getShippingRatesValidationComponents();
$paymentValidationComponents = $block->getPaymentValidationComponents();
$paymentListChildren = $block->getPaymentListChildren();
$paymentRegionChildren = $block->getPaymentRegionChildren();
$shippingListChildren = $block->getShippingListChildren();
$shippingAddressChildren = $block->getShippingAddressChildren();
$checkoutStepChildren = $block->getCheckoutStepChildren();
$layoutScripts = $block->getCheckoutLayoutScripts();

if (
    empty($rendererComponents) &&
    empty($rendererComponentMap) &&
    empty($shippingRatesValidationComponents) &&
    empty($paymentValidationComponents) &&
    empty($paymentListChildren) &&
    empty($paymentRegionChildren) &&
    empty($shippingListChildren) &&
    empty($shippingAddressChildren) &&
    empty($checkoutStepChildren) &&
    empty($layoutScripts['modules']) &&
    empty($layoutScripts['external'])
) {
    return;
}

$mageInitConfig = [
    'checkoutConfig' => $checkoutConfig,
    'paymentMethods' => $paymentMethods,
    'rendererComponents' => $rendererComponents,
    'rendererComponentMap' => $rendererComponentMap,
    'shippingRatesValidationComponents' => $shippingRatesValidationComponents,
    'paymentValidationComponents' => $paymentValidationComponents,
    'paymentListChildren' => $paymentListChildren,
    'paymentRegionChildren' => $paymentRegionChildren,
    'shippingListChildren' => $shippingListChildren,
    'shippingAddressChildren' => $shippingAddressChildren,
    'checkoutStepChildren' => $checkoutStepChildren,
    'layoutScripts' => $layoutScripts['modules'] ?? [],
    'layoutExternalScripts' => $layoutScripts['external'] ?? [],
    'scope' => 'fastcheckoutHyvaPaymentRenderers'
];
$block->ensureRequireJsAssets();
?>
