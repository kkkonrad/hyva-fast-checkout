<script>
(function () {
    // Safely define checkoutConfig and payment config inline before RequireJS is loaded/executed
    // We use a getter/setter to prevent subsequent scripts (e.g. from PayPal_Braintree) from overwriting it completely and removing key structures
    var serverConfig = <?= /* @noEscape */ \Laminas\Json\Json::encode($checkoutConfig) ?>;
    var existingConfig = window.checkoutConfig && typeof window.checkoutConfig === 'object'
        ? window.checkoutConfig
        : {};
    // Hyva or a payment module may define an empty checkoutConfig first. Keep
    // those additions, but always start with Magento's complete server config.
    var actualConfig = Object.assign({}, serverConfig, existingConfig);
    
    var initPaymentProxy = function(paymentObj) {
        paymentObj = paymentObj || {};
        // If it is already a Proxy, return it
        if (paymentObj.__isProxy) {
            return paymentObj;
        }
        return new Proxy(paymentObj, {
            get: function(target, prop) {
                if (prop === '__isProxy') {
                    return true;
                }
                if (prop === '__raw__') {
                    return target;
                }
                if (typeof prop === 'string' && !(prop in target)) {
                    target[prop] = {};
                }
                return target[prop];
            }
        });
    };

    Object.defineProperty(window, 'checkoutConfig', {
        get: function() {
            return actualConfig;
        },
        set: function(newConfig) {
            if (newConfig && typeof newConfig === 'object') {
                actualConfig = Object.assign(actualConfig, newConfig);
            } else {
                actualConfig = newConfig;
            }
            if (actualConfig && typeof actualConfig === 'object') {
                actualConfig.payment = initPaymentProxy(actualConfig.payment);
            }
        },
        configurable: true,
        enumerable: true
    });
    window.checkoutConfig = actualConfig;

    var config = <?= /* @noEscape */ \Laminas\Json\Json::encode($mageInitConfig) ?>;
    var requireJsUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('requirejs/require.js')) ?>';
    var requireJsConfigUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('requirejs-config.js')) ?>';
    var mixinsUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('mage/requirejs/mixins.js')) ?>';
    var staticBaseUrl = '<?= $escaper->escapeJs($block->getViewFileUrl('/')) ?>';
    var started = false;

    window.LOCALE = window.LOCALE || '<?= $escaper->escapeJs($block->getLocaleCode()) ?>';
    window.BASE_URL = window.BASE_URL || '<?= $escaper->escapeJs($block->getBaseUrl()) ?>';

    function loadScript(src, onload) {
        var script = document.createElement('script');

        script.src = src;
        script.async = false;
        script.onload = onload;
        script.onerror = function () {
            if (window.console && typeof window.console.warn === 'function') {
                window.console.warn('Kkkonrad Fastcheckout: could not load script', src);
            }
        };
        document.head.appendChild(script);
    }

    var originalGetElementById = document.getElementById;
    var originalQuerySelector = document.querySelector;
    var originalQuerySelectorAll = document.querySelectorAll;
    var originalGetElementsByClassName = document.getElementsByClassName;

    function getFastcheckoutRoot() {
        return originalGetElementById.call(document, 'fastcheckout-checkout');
    }

    function shouldSkipShadowLookup(selector) {
        return typeof selector === 'string' && (
            selector.indexOf('wire:') !== -1 ||
            selector.indexOf('x-') !== -1 ||
            selector.indexOf('[wire') !== -1 ||
            selector.indexOf('[x-') !== -1 ||
            selector.indexOf('livewire') !== -1 ||
            selector.indexOf('alpine') !== -1
        );
    }

    function getPaymentPlaceholders() {
        if (!getFastcheckoutRoot()) {
            return [];
        }

        return originalQuerySelectorAll.call(document, '[data-fastcheckout-payment-method-ko-target]');
    }

    function setupDomOverrides() {
        if (window.fastcheckoutKoDomOverridesApplied || !getFastcheckoutRoot()) {
            return;
        }

        window.fastcheckoutKoDomOverridesApplied = true;

        document.getElementById = function (id) {
            var el = originalGetElementById.call(document, id);
            if (!el) {
                var placeholders = getPaymentPlaceholders();
                for (var i = 0; i < placeholders.length; i++) {
                    if (placeholders[i].shadowRoot) {
                        el = placeholders[i].shadowRoot.getElementById(id);
                        if (el) break;
                    }
                }
            }
            return el;
        };

        document.querySelector = function (selector) {
            var el = null;
            try {
                el = originalQuerySelector.call(document, selector);
            } catch (e) {
                throw e;
            }
            if (!el) {
                if (shouldSkipShadowLookup(selector)) {
                    return el;
                }

                var placeholders = getPaymentPlaceholders();
                for (var i = 0; i < placeholders.length; i++) {
                    if (placeholders[i].shadowRoot) {
                        try {
                            el = placeholders[i].shadowRoot.querySelector(selector);
                            if (el) break;
                        } catch (e) {
                            // Ignore query errors in shadow DOM
                        }
                    }
                }
            }
            return el;
        };

        document.querySelectorAll = function (selector) {
            var lightList = [];
            try {
                lightList = Array.from(originalQuerySelectorAll.call(document, selector));
            } catch (e) {
                throw e;
            }
            
            if (shouldSkipShadowLookup(selector)) {
                return lightList;
            }

            var shadowElements = [];
            var placeholders = getPaymentPlaceholders();
            for (var i = 0; i < placeholders.length; i++) {
                if (placeholders[i].shadowRoot) {
                    try {
                        placeholders[i].shadowRoot.querySelectorAll(selector).forEach(function (el) {
                            shadowElements.push(el);
                        });
                    } catch (e) {
                        // Ignore query errors in shadow DOM
                    }
                }
            }
            return lightList.concat(shadowElements);
        };

        document.getElementsByClassName = function (className) {
            var lightList = Array.from(originalGetElementsByClassName.call(document, className));
            var shadowElements = [];
            var placeholders = getPaymentPlaceholders();
            for (var i = 0; i < placeholders.length; i++) {
                if (placeholders[i].shadowRoot) {
                    try {
                        placeholders[i].shadowRoot.querySelectorAll('.' + className).forEach(function (el) {
                            shadowElements.push(el);
                        });
                    } catch (e) {
                        // Ignore
                    }
                }
            }
            return lightList.concat(shadowElements);
        };
    }

    function initCheckoutBridge() {
        if (
            started ||
            window.fastcheckoutKoCheckoutRenderersStarted ||
            window.fastcheckoutKoCheckoutBridgeStarted ||
            window.fastcheckoutKoPaymentRenderersStarted ||
            typeof window.require !== 'function'
        ) {
            return;
        }

        setupDomOverrides();

        started = true;
        window.fastcheckoutKoCheckoutRenderersStarted = true;
        window.fastcheckoutKoCheckoutBridgeStarted = true;
        window.fastcheckoutKoPaymentRenderersStarted = true;
        window.require.config({
            baseUrl: staticBaseUrl
        });

        window.require(['Kkkonrad_Fastcheckout/js/hyva/checkout-renderers'], function (init) {
            init(config);
        });
    }

    function loadRequireJs() {
        if (typeof window.require === 'function') {
            window.require.config({
                baseUrl: staticBaseUrl
            });
            initCheckoutBridge();
            return;
        }

        loadScript(requireJsUrl, function () {
            if (typeof window.require === 'function') {
                window.require.config({
                    baseUrl: staticBaseUrl
                });
            }
            loadScript(requireJsConfigUrl, function () {
                loadScript(mixinsUrl, initCheckoutBridge);
            });
        });
    }

    function startAfterMagewire() {
        if (window.Magewire || window.Livewire) {
            loadRequireJs();
            return;
        }

        document.addEventListener('magewire:available', loadRequireJs, {once: true});
        document.addEventListener('livewire:available', loadRequireJs, {once: true});
        window.addEventListener('load', function () {
            setTimeout(loadRequireJs, 0);
        }, {once: true});
    }

    startAfterMagewire();
})();
</script>
