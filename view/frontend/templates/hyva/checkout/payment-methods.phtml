<?php
/**
 * Payment methods container block.
 *
 * @var \Kkkonrad\Fastcheckout\Block\Hyva\Checkout $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Kkkonrad\Fastcheckout\Magewire\Checkout $magewire
 * @var array $paymentMethods
 * @var array $allowedPaymentMethodCodes
 */
$paymentMethodAvailability = [];
$hasAvailablePaymentMethods = false;

foreach ($paymentMethods as $paymentMethod) {
    $paymentMethodCode = (string)$paymentMethod->getCode();
    $isAvailable = $magewire->isPaymentMethodAvailable($paymentMethodCode, $allowedPaymentMethodCodes);
    $paymentMethodAvailability[$paymentMethodCode] = $isAvailable;
    $hasAvailablePaymentMethods = $hasAvailablePaymentMethods || $isAvailable;
}
?>
<!-- Container 3: Payment Method -->
<div class="fc-container-3 space-y-6 min-w-0 w-full">
<!-- Payment Methods Section -->
<div class="card relative" wire:key="checkout-payment-methods-card">
    <div class="flex items-center justify-between border-b border-gray-200 pb-4 mb-4">
        <h2 class="text-xl font-semibold text-gray-900">
            <?= $escaper->escapeHtml(__('Payment Method')) ?>
        </h2>
    </div>

    <p class="text-sm text-gray-500<?= $hasAvailablePaymentMethods ? ' hidden' : '' ?>"
       role="status"
       data-fastcheckout-no-payment-methods
        <?= $hasAvailablePaymentMethods ? 'style="display: none;" aria-hidden="true"' : '' ?>>
        <?= $escaper->escapeHtml(__('No payment methods available.')) ?>
    </p>

    <?php if (!empty($paymentMethods)): ?>
        <div class="grid gap-3 relative min-h-[50px]<?= $hasAvailablePaymentMethods ? '' : ' hidden' ?>"
             wire:key="checkout-payment-methods-grid">
            <div wire:loading.flex
                 wire:target="countryId,regionId,region,postcode,city,street1,street2,fillFromSavedAddress,selectShippingMethod"
                 class="absolute inset-0 bg-white/80 backdrop-blur-[1px] z-20 rounded items-center justify-center transition-all duration-200"
                 style="display: none;">
                <svg class="animate-spin h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </div>
            <?php foreach ($paymentMethods as $method): ?>
                <?php
                $methodCode = $method->getCode();
                $isPaymentMethodAllowed = $paymentMethodAvailability[(string)$methodCode] ?? false;
                $isSelectedPayment = $isPaymentMethodAllowed && $magewire->isPaymentMethodSelected((string)$methodCode);
                ?>
                <div class="border rounded transition-all duration-200 border-gray-200 hover:border-gray-300"
                     wire:key="payment-method-item-<?= $escaper->escapeHtmlAttr($methodCode) ?>"
                     data-fastcheckout-payment-option="<?= $escaper->escapeHtmlAttr($methodCode) ?>"
                     data-fastcheckout-payment-allowed="<?= $isPaymentMethodAllowed ? '1' : '0' ?>"
                     <?= $isPaymentMethodAllowed ? '' : 'style="display:none;" aria-hidden="true"' ?>>
                    <label class="flex items-center gap-3 p-3 cursor-pointer hover:bg-gray-50/50 mb-0">
                        <input type="radio"
                               class="form-radio"
                               name="payment_method"
                               value="<?= $escaper->escapeHtmlAttr($methodCode) ?>"
                               data-fastcheckout-payment-option-input="<?= $escaper->escapeHtmlAttr($methodCode) ?>"
                               <?= $isSelectedPayment ? 'checked' : '' ?>
                                <?= $isPaymentMethodAllowed ? '' : 'disabled' ?>
                               required/>
                        <span class="font-medium text-sm text-gray-800"><?= $escaper->escapeHtml($method->getTitle()) ?></span>
                    </label>

                    <div class="fastcheckout-payment-method-ko-container border-t border-gray-100 hidden"
                         style="display: none;"
                         data-fastcheckout-payment-method-ko-target="<?= $escaper->escapeHtmlAttr($methodCode) ?>"
                         wire:ignore></div>
                </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</div>
</div>
