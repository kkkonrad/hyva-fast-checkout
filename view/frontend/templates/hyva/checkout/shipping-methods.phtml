<?php
/**
 * Shipping methods container block.
 *
 * @var \Kkkonrad\Fastcheckout\Block\Hyva\Checkout $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Kkkonrad\Fastcheckout\Magewire\Checkout $magewire
 */
$shippingMethods = $magewire->getShippingMethods();

$jsRates = [];
foreach ($shippingMethods as $carrierCode => $rates) {
    foreach ($rates as $rate) {
        $price = (float)$rate->getPrice();
        $jsRates[] = [
            'carrier_code' => (string)$rate->getCarrier(),
            'method_code' => (string)$rate->getMethod(),
            'carrier_title' => (string)$rate->getCarrierTitle(),
            'method_title' => (string)$rate->getMethodTitle(),
            'amount' => $price,
            'base_amount' => $price,
            'price_excl_tax' => $price,
            'price_incl_tax' => $price,
            'available' => !$rate->getErrorMessage(),
            'error_message' => (string)$rate->getErrorMessage(),
        ];
    }
}
?>
<!-- Container 2: Shipping Method -->
<div class="fc-container-2 space-y-6 min-w-0 w-full">
    <!-- Shipping Methods Section -->
    <div class="card bg-white p-4 md:p-6 shadow rounded-lg border border-gray-200 relative">
        <div class="flex items-center justify-between border-b border-gray-200 pb-4 mb-4">
            <h2 class="text-xl font-semibold text-gray-900">
                <?= $escaper->escapeHtml(__('Shipping Method')) ?>
            </h2>
            <div wire:loading wire:target="shippingAddress,countryId,regionId,region,postcode,city,street1,street2,fillFromSavedAddress,selectShippingMethod" class="text-xs text-blue-600 animate-pulse flex items-center gap-1.5">
                <svg class="animate-spin h-3.5 w-3.5 text-blue-600 inline" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="hidden md:inline"><?= $escaper->escapeHtml(__('Updating...')) ?></span>
            </div>
        </div>

        <div class="fastcheckout-ko-shipping-container">
            <div id="fastcheckout-ko-shipping-root"
                 class="fastcheckout-ko-shipping-root"
                 wire:ignore
                 data-bind="scope: 'fastcheckoutHyvaShippingRenderers.shippingList'">
                <!-- ko template: getTemplate() -->
                <?php if (empty($shippingMethods)): ?>
                    <p class="text-sm text-gray-500">
                        <?= $escaper->escapeHtml(__('Please enter your shipping address details to estimate shipping rates.')) ?>
                    </p>
                <?php else: ?>
                    <div class="grid gap-3 relative">
                        <?php foreach ($shippingMethods as $carrierCode => $rates): ?>
                            <?php foreach ($rates as $rate): ?>
                                <?php 
                                    $rateCode = $rate->getCarrier() . '_' . $rate->getMethod();
                                    $isSelected = ($magewire->shippingMethod === $rateCode);
                                    $cssClass = $isSelected 
                                        ? 'border-2 border-blue-500 bg-blue-50/10 shadow-sm' 
                                        : 'border-2 border-gray-200 hover:border-gray-300 hover:bg-gray-50/50';
                                ?>
                                <div class="rounded p-4 transition-all duration-200 <?= $escaper->escapeHtmlAttr($cssClass) ?>">
                                    <label class="flex items-center justify-between cursor-pointer mb-0 w-full">
                                        <div class="flex items-center min-w-0">
                                            <input type="radio" 
                                                   class="form-radio h-4 w-4 text-blue-600 focus:ring-blue-500 mr-4 shrink-0" 
                                                   name="shipping_method" 
                                                   value="<?= $escaper->escapeHtmlAttr($rateCode) ?>"
                                                   <?= $isSelected ? 'checked' : '' ?>
                                                   required />
                                            <div class="min-w-0 pl-4">
                                                <span class="block text-sm font-semibold text-gray-900 leading-tight">
                                                    <?= $escaper->escapeHtml($rate->getMethodTitle()) ?>
                                                </span>
                                                <span class="block text-xs text-gray-500 mt-1" id="label_carrier_<?= $escaper->escapeHtmlAttr($rate->getMethod() . '_' . $rate->getCarrier()) ?>">
                                                    <?= $escaper->escapeHtml($rate->getCarrierTitle()) ?>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="text-sm font-bold text-gray-900 shrink-0 pl-3">
                                            <?= /* @noEscape */ $block->formatPrice($rate->getPrice()) ?>
                                        </div>
                                    </label>
                                    <div id="label_method_<?= $escaper->escapeHtmlAttr($rate->getMethod() . '_' . $rate->getCarrier()) ?>"></div>
                                </div>
                            <?php endforeach; ?>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
                <!-- /ko -->
            </div>
        </div>
    </div>
</div>
<script>
    window.fastcheckoutInitialShippingRates = <?= /* @noEscape */ json_encode($jsRates) ?>;
    window.fastcheckoutInitialShippingMethod = <?= /* @noEscape */ json_encode($magewire->shippingMethod) ?>;
</script>
