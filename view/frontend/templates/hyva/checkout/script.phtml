        const emailToKeep = resolveEmailForPersistence();
        window.fastcheckoutOrderPlaced = true;
        try { sessionStorage.setItem(ORDER_PLACED_MARKER, '1'); } catch (e) {}
        clearStorage();
        // Re-save email into session so restore() can fill wire/DOM before KO boots.
        if (emailToKeep) {
            try { sessionStorage.setItem(PREFIX + 'email', emailToKeep); } catch (e) {}
        }
        clearCheckoutDataStorage(emailToKeep);
    }

    function getWire() {
        const el = document.querySelector('[wire\\:id]');
        return el ? (window.Livewire && window.Livewire.find(el.getAttribute('wire:id'))) : null;
    }

    resetOrderPlacedStateForActiveCheckout();

    window.addEventListener('pageshow', function () {
        resetOrderPlacedStateForActiveCheckout();
    });

    if (window.Livewire) {
        window.Livewire.hook('message.processed', function (message, component) {
            if (window.fastcheckoutOrderPlaced) return;
            if (!component || !component.data) return;
            FIELDS.forEach(function (field) {
                try { save(field, component.data[field]); } catch (e) {}
            });
            // Only re-apply while restore is still pending and under the follow-up cap.
            if (
                window.fastcheckoutGuestAddressSnapshotRestorePending === true &&
                lastGuestRestoreValues &&
                lastGuestRestoreAttempts < GUEST_RESTORE_FOLLOWUP_MS.length
            ) {
                reapplyRecentGuestAddressIfNeeded(getWire());
            }
        });
    }

    // Save inputs instantly on user typing to ensure robust recovery and test compatibility
    document.addEventListener('input', function (event) {
        var target = event.target;
        if (!target) return;
        if (window.fastcheckoutOrderPlaced) return;
        var field = target.dataset.wireField;
        if (field && FIELDS.includes(field)) {
            save(field, target.value);
        }
    });

    window.addEventListener('fastcheckout:address-fields-ready', function () {
        const wire = getWire();
        if (wire) {
            restore(wire);
        }
    }, {once: true});

    document.addEventListener('DOMContentLoaded', function () {
        setTimeout(function () {
            const wire = getWire();
            if (wire) restore(wire);
            window.addEventListener('magewire:order-placed', function (event) {
                clearPersistedCheckoutState();
                if (
                    window.fastcheckoutHyvaPayment &&
                    typeof window.fastcheckoutHyvaPayment.handleOrderPlaced === 'function' &&
                    window.fastcheckoutHyvaPayment.handleOrderPlaced(event.detail || {})
                ) {
                    return;
                }
                if (event.detail && event.detail.redirectUrl) {
                    window.location.replace(event.detail.redirectUrl);
                    return;
                }
                if (window.fastcheckoutHyvaPayment && typeof window.fastcheckoutHyvaPayment.afterPlaceOrder === 'function') {
                    window.fastcheckoutHyvaPayment.afterPlaceOrder();
                } else {
                    require(['mage/url'], function (url) {
                        window.location.replace(url.build('checkout/onepage/success'));
                    });
                }
            });
            if (isCheckoutSuccessPage()) {
                clearPersistedCheckoutState();
            }
        }, 400);
    });
})();
</script>
<?php $hyvaCsp->registerInlineScript() ?>
