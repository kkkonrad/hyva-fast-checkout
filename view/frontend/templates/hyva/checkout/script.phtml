<?php
/**
 * Checkout Alpine.js script, sessionStorage backup logic, and layout overrides.
 *
 * @var \Kkkonrad\Fastcheckout\Block\Hyva\Checkout $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Kkkonrad\Fastcheckout\Magewire\Checkout $magewire
 * @var \Hyva\Theme\ViewModel\HyvaCsp $hyvaCsp
 */
?>
<script>
/**
 * Shared shipping/billing field catalogue used by Alpine, sessionStorage restore, and DOM snapshots.
 * Keep in sync with Magewire SYNCABLE_ADDRESS_FIELDS (minus paymentMethod / billingSameAsShipping).
 */
window.fastcheckoutAddressFields = [
    'email', 'firstname', 'lastname', 'company',
    'street1', 'street2', 'street3', 'street4',
    'prefix', 'middlename', 'suffix', 'fax', 'vatId',
    'city', 'postcode', 'countryId', 'regionId', 'region', 'telephone',
    'billingFirstname', 'billingLastname', 'billingCompany',
    'billingStreet1', 'billingStreet2', 'billingStreet3', 'billingStreet4',
    'billingPrefix', 'billingMiddlename', 'billingSuffix', 'billingFax', 'billingVatId',
    'billingCity', 'billingPostcode', 'billingCountryId', 'billingRegionId',
    'billingRegion', 'billingTelephone'
];

/**
 * Kkkonrad Fastcheckout Alpine component — CSP compatible (Hyva Alpine CSP pattern)
 * No inline expressions in x-data or event attributes.
 */
function initCheckout() {
    return {
        _debounceTimers: {},
        _blurTimers: {},
        _addressSyncTimer: null,
        _addressSyncInFlight: null,
        _addressSyncQueued: false,
        _lastSyncedAddressJson: null,
        _fieldValueOnFocus: null,
        _pendingRateAddressSave: false,
        // Soft text fields coalesce; rate-affecting fields flush sooner for shipping estimates.
        SOFT_SAVE_DEBOUNCE_MS: 450,
        RATE_SAVE_DEBOUNCE_MS: 80,
        RATE_AFFECTING_FIELDS: [
            'countryId', 'regionId', 'region', 'postcode', 'city',
            'billingCountryId', 'billingRegionId', 'billingRegion',
            'billingPostcode', 'billingCity'
        ],
        isProcessing: false,
        clientOrderError: '',

        init() {
            window.addEventListener('fastcheckout:payment-error', (event) => {
                this.onPaymentError(event);
            });
            window.addEventListener('fastcheckout:shipping-error', (event) => {
                this.onPaymentError(event);
            });

            // Push Magewire → KO only after server-side updates (syncAddressFields, selects),
            // not while the shopper is typing into unbound DOM inputs.
            // Native Magento UI components own address state through checkoutProvider.
            // Watching Magewire address properties here would replay a server response
            // over fields the shopper has just edited. Payment selection still needs
            // the legacy Magewire -> KO watcher.
            const fieldsToWatch = ['paymentMethod'];

            fieldsToWatch.forEach((field) => {
                this.$watch(`$wire.${field}`, (value) => {
                    if (
                        !window.fastcheckoutHyvaPayment ||
                        typeof window.fastcheckoutHyvaPayment.syncFieldToKo !== 'function'
                    ) {
                        return;
                    }
                    // Always push server → KO (even during DOM→Magewire flush). Suppress only
                    // the KO→Magewire feedback path while applying the value.
                    window.fastcheckoutSuppressKoAddressToMagewire = true;
                    try {
                        window.fastcheckoutHyvaPayment.syncFieldToKo(field, value);
                    } finally {
                        window.setTimeout(() => {
                            window.fastcheckoutSuppressKoAddressToMagewire = false;
                        }, 0);
                    }
                });
            });

            this.$nextTick(() => {
                if (window.fastcheckoutHyvaShipping && typeof window.fastcheckoutHyvaShipping.syncAddress === 'function') {
                    window.fastcheckoutHyvaShipping.syncAddress(this.$wire);
                    if (this.$wire.shippingMethod) {
                        window.fastcheckoutHyvaShipping.syncShippingMethod(this.$wire.shippingMethod);
                    }
                }
                // Baseline: current DOM already matches server-rendered state — do not XHR on first blur-without-edit.
                this._lastSyncedAddressJson = this.serializeAddressPayload(this.collectAddressFieldsFromDom());
            });

            // Field commit outside Alpine @blur (browser autofill / some password managers).
            // Saves once when a data-wire-field value is committed, not on every keystroke.
            const formRoot = this.$el;
            if (formRoot && typeof formRoot.addEventListener === 'function') {
                formRoot.addEventListener('focusin', (event) => {
                    const target = event && event.target;
                    if (!target || !target.dataset || !target.dataset.wireField) {
                        return;
                    }
                    // Remember value at focus so blur can skip no-op saves (clicking between fields).
                    this._fieldValueOnFocus = target.value;
                    this._fieldFocused = target;
                }, true);

                formRoot.addEventListener('change', (event) => {
                    const target = event && event.target;
                    if (!target || !target.dataset || !target.dataset.wireField) {
                        return;
                    }
                    if (target.closest('.fastcheckout-native-shipping-address, .payment-method-billing-address')) {
                        return;
                    }
                    // Selects already call onSelectChange (immediate flush).
                    if (target.tagName === 'SELECT') {
                        return;
                    }
                    this.queueAddressFieldSave(target);
                }, true);
            }

            if (window.Livewire && typeof window.Livewire.hook === 'function') {
                window.Livewire.hook('message.processed', (message) => {
                    const updates = message.updateQueue || (message.payload && message.payload.updates) || [];
                    const isPlacingOrder = updates.some(update => 
                        update.type === 'callMethod' && update.payload && update.payload.method === 'placeOrder'
                    );
                    if (isPlacingOrder) {
                        const hasError = this.$wire.orderError || (typeof this.$wire.get === 'function' ? this.$wire.get('orderError') : '');
                        if (hasError) {
                            this.isProcessing = false;
                            document.body.classList.remove('checkout-submitting');
                            this.unlockScrollForPlaceOrder();
                            // Server-side placeOrder errors (address, agreements, etc.) — stay near CTA on mobile.
                            if (this.shouldScrollToPaymentOnError({ message: String(hasError) })) {
                                this.scrollToSelectedPaymentMethod();
                            }
                        }
                    }
                });
                window.Livewire.hook('message.failed', () => {
                    this.isProcessing = false;
                    document.body.classList.remove('checkout-submitting');
                    this.unlockScrollForPlaceOrder();
                });
                window.Livewire.hook('element.updating', (fromEl, toEl) => {
                    if (window.fastcheckoutOrderPlaced) {
                        return false;
                    }
                });
            }
        },

        /**
         * Collect current shipping/billing values from the live form DOM.
         * Prefer DOM over $wire so rapid typing is never lost to Magewire races.
         */
        collectAddressFieldsFromDom() {
            const form = document.getElementById('co-checkout-form') || this.$el;
            const payload = {};
            const fields = window.fastcheckoutAddressFields || [];

            fields.forEach((field) => {
                const el = form.querySelector('[data-wire-field="' + field + '"]')
                    || form.querySelector('[wire\\:model\\.blur="' + field + '"]')
                    || form.querySelector('[wire\\:model\\.defer="' + field + '"]')
                    || form.querySelector('[wire\\:model="' + field + '"]');
                if (!el) {
                    return;
                }
                if (el.type === 'checkbox') {
                    payload[field] = !!el.checked;
                } else {
                    payload[field] = el.value;
                }
            });

            const sameAs = form.querySelector('[wire\\:model="billingSameAsShipping"], input[type="checkbox"][wire\\:model="billingSameAsShipping"]');
            if (sameAs) {
                payload.billingSameAsShipping = !!sameAs.checked;
            }

            // Do NOT push shippingMethod from DOM here. Multiple radio groups / morph races can
            // re-apply a stale checked rate and undo selectShippingMethod (breaks payment filters).
            // Shipping is owned by KO → selectShippingMethod(). Payment is safe to collect for place-order.
            const payment = form.querySelector('input[name="payment_method"]:checked:not(:disabled)');
            if (payment && payment.value) {
                payload.paymentMethod = payment.value;
            }

            return payload;
        },

        /**
         * Stable JSON for dirty-checking address snapshots.
         * paymentMethod is owned by payment selection — ignore it here so picking
         * a payment does not make the next address blur look "dirty".
         */
        serializeAddressPayload(payload) {
            const data = payload && typeof payload === 'object' ? payload : {};
            const keys = Object.keys(data).sort().filter((key) => key !== 'paymentMethod');
            const normalized = {};
            keys.forEach((key) => {
                const value = data[key];
                normalized[key] = value === null || value === undefined ? '' : String(value);
            });
            return JSON.stringify(normalized);
        },

        /**
         * True when live DOM address differs from the last successful Magewire save.
         */
        isAddressPayloadDirty(payload) {
            const next = this.serializeAddressPayload(payload || this.collectAddressFieldsFromDom());
            return next !== (this._lastSyncedAddressJson || '');
        },

        /**
         * Debounced atomic address sync — one Magewire round-trip for all form fields.
         */
        scheduleAddressSync(delayMs) {
            const delay = typeof delayMs === 'number' ? delayMs : 180;
            if (this._addressSyncTimer) {
                clearTimeout(this._addressSyncTimer);
            }
            this._addressSyncTimer = setTimeout(() => {
                this._addressSyncTimer = null;
                this.flushAddressSync();
            }, delay);
        },

        /**
         * @param {boolean} force When true, always push (place order / country select).
         */
        flushAddressSync(force) {
            if (!this.$wire || typeof this.$wire.call !== 'function') {
                return Promise.resolve();
            }

            if (
                window.fastcheckoutHyvaShipping &&
                typeof window.fastcheckoutHyvaShipping.syncAddressFormsToMagewire === 'function'
            ) {
                return Promise.resolve(window.fastcheckoutHyvaShipping.syncAddressFormsToMagewire());
            }

            if (this._addressSyncInFlight) {
                this._addressSyncQueued = true;
                this._addressSyncQueuedForce = this._addressSyncQueuedForce || force === true;
                return this._addressSyncInFlight;
            }

            const payload = this.collectAddressFieldsFromDom();
            const payloadJson = this.serializeAddressPayload(payload);

            // Skip no-op XHR (e.g. focus→blur without edit, or clicking between fields).
            if (force !== true && payloadJson === (this._lastSyncedAddressJson || '')) {
                return Promise.resolve();
            }

            // Block KO quote → wire.set feedback while we push the DOM snapshot.
            window.fastcheckoutSuppressKoAddressToMagewire = true;
            this._addressSyncInFlight = Promise.resolve(this.$wire.call('syncAddressFields', payload))
                .then(() => {
                    this._lastSyncedAddressJson = payloadJson;
                })
                .catch((error) => {
                    if (window.console && typeof window.console.warn === 'function') {
                        window.console.warn('Kkkonrad Fastcheckout: address sync failed', error);
                    }
                })
                .finally(() => {
                    this._addressSyncInFlight = null;
                    window.setTimeout(() => {
                        window.fastcheckoutSuppressKoAddressToMagewire = false;
                    }, 50);
                    if (this._addressSyncQueued) {
                        const queuedForce = this._addressSyncQueuedForce === true;
                        this._addressSyncQueued = false;
                        this._addressSyncQueuedForce = false;
                        this.flushAddressSync(queuedForce);
                    }
                });

            return this._addressSyncInFlight;
        },

        /**
         * Typing handler — local only (format helpers, email validity).
         * Does NOT push to Magewire on every keystroke; server save runs on blur/change.
         */
        onFieldInput() {
            const el = this.$el;
            const field = el.dataset.wireField;
            if (!field) return;

            // Debounced validity validation for email (UI only — no address XHR).
            if (field === 'email') {
                if (!this._debounceTimers) {
                    this._debounceTimers = {};
                }
                if (this._debounceTimers['email_val']) {
                    clearTimeout(this._debounceTimers['email_val']);
                }
                this._debounceTimers['email_val'] = setTimeout(() => {
                    this._validateEl(el);
                    delete this._debounceTimers['email_val'];
                }, 800);
            }
        },

        /**
         * Save address snapshot when leaving a field (blur / field change).
         * Soft fields coalesce (~450ms); rate-affecting fields flush sooner (~80ms).
         * No Magewire request when the form is unchanged (click/tab between fields).
         *
         * @param {Element|string|null} fieldOrEl
         */
        queueAddressFieldSave(fieldOrEl) {
            let field = '';
            let el = null;
            if (typeof fieldOrEl === 'string') {
                field = fieldOrEl;
            } else if (fieldOrEl && fieldOrEl.dataset) {
                el = fieldOrEl;
                field = fieldOrEl.dataset.wireField || '';
            } else if (this.$el && this.$el.dataset) {
                el = this.$el;
                field = this.$el.dataset.wireField || '';
            }

            // Fast path: same field value as on focus and no other form changes.
            if (
                el &&
                this._fieldFocused === el &&
                String(el.value || '') === String(this._fieldValueOnFocus || '') &&
                !this.isAddressPayloadDirty()
            ) {
                return;
            }

            const rateFields = this.RATE_AFFECTING_FIELDS || [];
            if (field && rateFields.indexOf(field) !== -1) {
                this._pendingRateAddressSave = true;
            }

            if (!this._blurTimers) {
                this._blurTimers = {};
            }
            // Single shared timer — multiple field blurs coalesce into one save.
            // Rate field (or mixed soft+rate batch) uses the shorter debounce.
            const timerKey = '_address';
            const delay = this._pendingRateAddressSave
                ? (this.RATE_SAVE_DEBOUNCE_MS || 80)
                : (this.SOFT_SAVE_DEBOUNCE_MS || 450);
            if (this._blurTimers[timerKey]) {
                clearTimeout(this._blurTimers[timerKey]);
            }
            this._blurTimers[timerKey] = setTimeout(() => {
                delete this._blurTimers[timerKey];
                this._pendingRateAddressSave = false;
                if (!this.isAddressPayloadDirty()) {
                    return;
                }
                this.scheduleAddressSync(0);
            }, delay);
        },

        /**
         * Save + validation — called from @blur on required fields.
         */
        onFieldBlur() {
            this.queueAddressFieldSave(this.$el);
            this._validateEl(this.$el);
        },

        /**
         * Save without validation — called from @blur on optional fields.
         */
        onFieldBlurNoValidate() {
            this.queueAddressFieldSave(this.$el);
        },

        /**
         * Fires when the field value is committed (blur after edit, or some autofill).
         * Same as blur save — safe if both fire (debounced/coalesced).
         */
        onFieldChange() {
            this.queueAddressFieldSave(this.$el);
        },

        /**
         * Validation only — for fields using wire:model.blur.
         */
        onFieldBlurValidateOnly() {
            this._validateEl(this.$el);
        },

        /**
         * Validate select on change.
         */
        onSelectChange() {
            const el = this.$el;
            const field = el.dataset.wireField || '';

            // Country / region changes affect rates — flush the whole form snapshot.
            // Address block uses wire:ignore, so rebuild region <option>s client-side.
            Promise.resolve(this.flushAddressSync())
                .then(() => {
                    if (field === 'countryId' || field === 'billingCountryId') {
                        return this.refreshRegionOptions(field);
                    }
                })
                .catch(() => {});

            this._validateEl(el);
        },

        /**
         * Rebuild region select options after country change (wire:ignore blocks morph).
         */
        refreshRegionOptions(countryField) {
            if (!this.$wire || typeof this.$wire.call !== 'function') {
                return Promise.resolve();
            }

            const isBilling = countryField === 'billingCountryId';
            const method = isBilling ? 'getBillingRegions' : 'getRegions';
            const select = document.querySelector(
                isBilling
                    ? 'select[data-wire-field="billingRegionId"]'
                    : 'select[data-wire-field="regionId"]'
            );

            return Promise.resolve(this.$wire.call(method))
                .then((regions) => {
                    if (!select || !Array.isArray(regions)) {
                        return;
                    }
                    const previous = select.value;
                    const placeholder = select.querySelector('option[value=""]');
                    select.innerHTML = '';
                    if (placeholder) {
                        select.appendChild(placeholder);
                    } else {
                        const empty = document.createElement('option');
                        empty.value = '';
                        select.appendChild(empty);
                    }
                    regions.forEach((opt) => {
                        if (!opt || opt.value === undefined || opt.value === null || opt.value === '') {
                            return;
                        }
                        const option = document.createElement('option');
                        option.value = String(opt.value);
                        option.textContent = opt.label || String(opt.value);
                        select.appendChild(option);
                    });
                    const hasPrevious = previous && Array.prototype.some.call(
                        select.options,
                        (option) => option.value === previous
                    );
                    select.value = hasPrevious ? previous : '';
                })
                .catch(() => {});
        },

        /**
         * Fill all shipping fields from a saved customer address.
         * Reads the selected value from the select whose id is in data-select-id.
         */
        fillSavedAddress() {
            const selectId = this.$el.dataset.selectId;
            const sel = selectId ? document.getElementById(selectId) : null;
            if (!sel) return;
            const id = parseInt(sel.value, 10);
            if (id > 0) {
                this.$wire.call('fillFromSavedAddress', id);
            }
        },

        /**
         * Scroll to the selected payment method block (validation failures only).
         */
        scrollToSelectedPaymentMethod() {
            // Must unlock freeze first, otherwise scrollIntoView is no-op / fights body:fixed.
            this.unlockScrollForPlaceOrder();
            const selectedMethodEl = document.querySelector('input[name="payment_method"]:checked');
            const paymentCard = document.querySelector('.fc-container-3, [data-fastcheckout-payment-option]');
            let target = null;
            if (selectedMethodEl) {
                target = selectedMethodEl.closest('[data-fastcheckout-payment-option]') || selectedMethodEl;
            } else {
                target = paymentCard;
            }
            if (target && typeof target.scrollIntoView === 'function') {
                // rAF: wait one frame after body unlock so layout is scrollable again.
                window.requestAnimationFrame(() => {
                    target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                });
            }
        },

        /**
         * Prefer showing the order error near the place-order controls instead of jumping to payment.
         */
        scrollToOrderError() {
            // On mobile sticky CTA, stay put — user already pressed the button there.
            if (window.matchMedia && window.matchMedia('(max-width: 767px)').matches) {
                return;
            }
            const errorEl = document.querySelector(
                '#co-checkout-form .text-red-600, #co-checkout-form [x-text="clientOrderError"]'
            );
            if (errorEl && typeof errorEl.scrollIntoView === 'function') {
                errorEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        },

        isPaymentValidationError(err) {
            const msg = String((err && err.message) || err || '').toLowerCase();
            if (!msg) {
                return false;
            }
            const needles = [
                'check the selected payment',
                'required field',
                'not ready',
                'did not start order',
                'purchase order',
                'agree to the terms',
                'validation',
                'sprawdź wybraną',
                'wymagane pole',
                'nie jest jeszcze gotowa',
                'nie rozpoczęła składania',
                'regulamin',
                'pickup point',
                'punkt odbioru',
                'pobraniem'
            ];
            return needles.some((n) => msg.indexOf(n) !== -1);
        },

        hasVisiblePaymentValidationUi() {
            return !!document.querySelector(
                '[data-fastcheckout-payment-option] .mage-error,' +
                '[data-fastcheckout-payment-option] [aria-invalid="true"],' +
                '[data-fastcheckout-payment-option] .field-error,' +
                '.payment-method._active .mage-error,' +
                '.payment-method._active .field-error,' +
                'div.checkout-agreements .mage-error'
            );
        },

        shouldScrollToPaymentOnError(err) {
            return this.isPaymentValidationError(err) || this.hasVisiblePaymentValidationUi();
        },

        /**
         * Freeze viewport during place-order so Magewire morph / KO focus / native
         * form focus cannot yank the page to the payment block (no bounce-back either).
         */
        lockScrollForPlaceOrder() {
            if (this._scrollFrozen) {
                return;
            }
            const y = window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0;
            this._placeOrderScrollY = y;
            this._scrollFrozen = true;
            this._allowPaymentScroll = false;

            const body = document.body;
            const html = document.documentElement;
            this._scrollLockStyles = {
                bodyPosition: body.style.position,
                bodyTop: body.style.top,
                bodyLeft: body.style.left,
                bodyRight: body.style.right,
                bodyWidth: body.style.width,
                bodyOverflow: body.style.overflow,
                htmlOverflow: html.style.overflow,
                htmlScrollBehavior: html.style.scrollBehavior
            };

            html.style.scrollBehavior = 'auto';
            html.style.overflow = 'hidden';
            body.style.position = 'fixed';
            body.style.top = '-' + y + 'px';
            body.style.left = '0';
            body.style.right = '0';
            body.style.width = '100%';
            body.style.overflow = 'hidden';
            body.classList.add('fastcheckout-scroll-locked');

            // Magento KO / browser often call scrollIntoView on payment radios or invalid fields.
            if (!this._origScrollIntoView) {
                this._origScrollIntoView = Element.prototype.scrollIntoView;
                const self = this;
                Element.prototype.scrollIntoView = function () {
                    if (self._scrollFrozen && !self._allowPaymentScroll) {
                        return;
                    }
                    return self._origScrollIntoView.apply(this, arguments);
                };
            }

            // window.scrollTo / scroll during freeze — keep pinned.
            if (!this._origWindowScrollTo) {
                this._origWindowScrollTo = window.scrollTo.bind(window);
                const self = this;
                window.scrollTo = function () {
                    if (self._scrollFrozen && !self._allowPaymentScroll) {
                        return;
                    }
                    return self._origWindowScrollTo.apply(window, arguments);
                };
            }
        },

        unlockScrollForPlaceOrder() {
            if (!this._scrollFrozen && !this._scrollLockStyles) {
                // Still restore prototype patches if any.
                if (this._origScrollIntoView) {
                    Element.prototype.scrollIntoView = this._origScrollIntoView;
                    this._origScrollIntoView = null;
                }
                if (this._origWindowScrollTo) {
                    window.scrollTo = this._origWindowScrollTo;
                    this._origWindowScrollTo = null;
                }
                return;
            }

            const y = this._placeOrderScrollY || 0;
            const body = document.body;
            const html = document.documentElement;
            const saved = this._scrollLockStyles || {};

            this._scrollFrozen = false;
            this._allowPaymentScroll = false;
            body.classList.remove('fastcheckout-scroll-locked');

            body.style.position = saved.bodyPosition || '';
            body.style.top = saved.bodyTop || '';
            body.style.left = saved.bodyLeft || '';
            body.style.right = saved.bodyRight || '';
            body.style.width = saved.bodyWidth || '';
            body.style.overflow = saved.bodyOverflow || '';
            html.style.overflow = saved.htmlOverflow || '';
            html.style.scrollBehavior = saved.htmlScrollBehavior || '';
            this._scrollLockStyles = null;
            this._placeOrderScrollY = null;

            if (this._origScrollIntoView) {
                Element.prototype.scrollIntoView = this._origScrollIntoView;
                this._origScrollIntoView = null;
            }
            if (this._origWindowScrollTo) {
                window.scrollTo = this._origWindowScrollTo;
                this._origWindowScrollTo = null;
            }

            // Restore exact pre-submit position (no smooth — avoid visual jump).
            window.scrollTo(0, y);
        },

        /**
         * Handle form submit — validate all, sync address snapshot, then place order.
         */
        handleSubmit() {
            this.clientOrderError = '';

            // Standard Magento UI components need to validate first. In
            // particular, their required rules are data-validate/KO rules and
            // are not visible to the browser's native form validity API.
            //
            // Run shipping + separate billing validation together so both forms
            // paint errors in one Place Order click (no short-circuit on shipping).
            const paymentBridge = window.fastcheckoutHyvaPayment;
            let shippingValid = true;
            let billingValid = true;

            if (window.fastcheckoutHyvaShipping && typeof window.fastcheckoutHyvaShipping.validate === 'function') {
                shippingValid = window.fastcheckoutHyvaShipping.validate() !== false;
            }

            // Paint billing errors without stealing focus — after both validators run
            // we jump to the first invalid field in document order (email/shipping first).
            if (paymentBridge && typeof paymentBridge.validateBillingAddress === 'function') {
                billingValid = paymentBridge.validateBillingAddress({ focus: false }) !== false;
            }

            if (!shippingValid || !billingValid) {
                const missingShippingMethodMessage = <?= /* @noEscape */ json_encode(
                    (string)__('Please select a shipping method.')
                ) ?>;
                const hasShippingMethodSelected = !!document.querySelector(
                    'input[name="shipping_method"]:checked:not(:disabled)'
                );

                if (window.console && typeof window.console.warn === 'function') {
                    window.console.warn(
                        'Kkkonrad Fastcheckout: Order placement halted because address validation failed.',
                        { shippingValid, billingValid }
                    );
                }

                // Missing shipping method: show a user-visible message immediately
                // (do not rely only on console / late rAF focus logic).
                if (!shippingValid && !hasShippingMethodSelected) {
                    this.clientOrderError =
                        window.fastcheckoutLastShippingValidationError ||
                        missingShippingMethodMessage;

                    const shippingRoot = document.getElementById('fastcheckout-ko-shipping-root') ||
                        document.querySelector('[name="shipping_method"]');
                    if (shippingRoot && typeof shippingRoot.scrollIntoView === 'function') {
                        shippingRoot.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                    return;
                }

                // rAF: wait for KO to paint aria-invalid / shipping-method errors.
                window.requestAnimationFrame(() => {
                    const shippingRoot = document.getElementById('fastcheckout-ko-shipping-root') ||
                        document.querySelector('[name="shipping_method"]');

