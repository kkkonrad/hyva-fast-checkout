<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Magento\Downloadable\Observer\IsAllowedGuestCheckoutObserver" type="Kkkonrad\Fastcheckout\Observer\Downloadable\IsAllowedGuestCheckoutObserver"/>
    <preference for="Magento\Checkout\Helper\Data" type="Kkkonrad\Fastcheckout\Helper\Checkout\Data"/>



    <type name="Magento\Customer\Model\Address\AbstractAddress">
        <plugin name="fastcheckout_customer_address" type="Kkkonrad\Fastcheckout\Plugin\Customer\Model\Address\AbstractAddress"/>
    </type>
    <type name="Magento\Payment\Model\InfoInterface">
        <plugin name="fastcheckout_unset_extension_attributes" type="Kkkonrad\Fastcheckout\Plugin\Payments\Info"/>
    </type>
    <type name="Magento\Quote\Api\CartRepositoryInterface">
        <plugin name="fastcheckout_preserve_inpost_locker" type="Kkkonrad\Fastcheckout\Plugin\Quote\PreserveInpostLocker"/>
    </type>
    <type name="Magento\Quote\Model\CustomerManagement">
        <plugin name="fastcheckout_quote_customermanagement" type="Kkkonrad\Fastcheckout\Plugin\Quote\CustomerManagementPlugin"/>
    </type>

    <type name="Tpay\Magento2\Model\ApiFacade\TpayConfig\ConfigOpen">
        <plugin name="fastcheckout_tpay_config_open" type="Kkkonrad\Fastcheckout\Plugin\Tpay\PatchTpayChannelsScript"/>
    </type>
    <type name="Tpay\Magento2\Model\ApiFacade\TpayConfig\ConfigOrigin">
        <plugin name="fastcheckout_tpay_config_origin" type="Kkkonrad\Fastcheckout\Plugin\Tpay\PatchTpayChannelsScript"/>
    </type>

</config>
